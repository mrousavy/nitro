{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["test"],
  "ios": {
    "iosModuleName": "NitroTest"
  },
  "android": {
    "androidNamespace": ["test"],
    "androidCxxLibName": "NitroTest"
  },
  "autolinking": {
    "TestObjectCpp": {
      "all": {
        "language": "cpp",
        "implementationClassName": "HybridTestObjectCpp"
      }
    },
    "TestObjectSwiftKotlin": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTestObjectSwift"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTestObjectKotlin"
      }
    },
    "Base": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridBase"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridBase"
      }
    },
    "Child": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridChild"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridChild"
      }
    },
    "PlatformObject": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPlatformObject"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPlatformObject"
      }
    },
    "TestView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTestView"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTestView"
      }
    },
    "RecyclableTestView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridRecyclableTestView"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridRecyclableTestView"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ],
  "gitAttributesGeneratedFlag": false
}
