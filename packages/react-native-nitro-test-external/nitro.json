{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["test", "external"],
  "ios": {
    "iosModuleName": "NitroTestExternal"
  },
  "android": {
    "androidNamespace": ["test", "external"],
    "androidCxxLibName": "NitroTestExternal"
  },
  "autolinking": {
    "SomeExternalObject": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSomeExternalObject"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridSomeExternalObject"
      }
    },
    "TestView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTestView"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTestView"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
